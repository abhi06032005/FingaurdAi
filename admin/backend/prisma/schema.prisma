generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id
  clerkUserId    String    @unique
  name           String    @default("")
  email          String    @unique
  role           String    @default("USER")
  plan           String    @default("FREE")
  reportsUsed    Int       @default(0)
  planStartDate  DateTime?
  planExpiryDate DateTime?
  isPremium      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  webinarRegistrations WebinarRegistration[]
}

model Candle {
  symbol      String
  date        DateTime  @db.Date
  open        Decimal   @db.Decimal(12, 4)
  high        Decimal   @db.Decimal(12, 4)
  low         Decimal   @db.Decimal(12, 4)
  close       Decimal   @db.Decimal(12, 4)
  volume      BigInt
  dataQuality Int       @default(100)
  createdAt   DateTime  @default(now())

  @@id([symbol, date])
  @@index([symbol, date(sort: Desc)])
  @@map("candles")
}

model TechnicalAnalysisCache {
  symbol         String   @id
  resultJson     Json
  technicalScore Decimal  @db.Decimal(5, 2)
  candleDate     DateTime @db.Date
  calculatedAt   DateTime @default(now())
  isStale        Boolean  @default(false)

  @@map("technical_analysis_cache")
}

model ScoreHistory {
  id              BigInt   @id @default(autoincrement())
  symbol          String
  date            DateTime @db.Date
  technicalScore  Decimal  @db.Decimal(5, 2)
  technicalRating String
  confluenceScore Decimal? @db.Decimal(5, 2)
  recordedAt      DateTime @default(now())

  @@unique([symbol, date])
  @@index([symbol, date(sort: Desc)])
  @@map("score_history")
}

model IngestionLog {
  id             BigInt   @id @default(autoincrement())
  symbol         String
  runDate        DateTime @db.Date
  status         String
  candlesFetched Int?
  errorMessage   String?
  durationMs     Int?
  loggedAt       DateTime @default(now())

  @@map("ingestion_log")
}

model Webinar {
  id           String                @id @default(uuid())
  title        String
  description  String
  speaker      String
  startTime    DateTime
  endTime      DateTime
  zoomLink     String
  type         String                @default("FREE") // "FREE" or "PREMIUM"
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  registrations WebinarRegistration[]

  @@map("webinars")
}

model WebinarRegistration {
  id           String   @id @default(uuid())
  webinarId    String
  userId       String
  registeredAt DateTime @default(now())
  
  webinar      Webinar  @relation(fields: [webinarId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([webinarId, userId])
  @@map("webinar_registrations")
}

// ─── AI Stock Screener ────────────────────────────────────────────────────────

model StockMetadata {
  symbol            String  @id
  companyName       String  @default("")
  sector            String  @default("Unknown")
  industry          String  @default("Unknown")
  marketCapCategory String  @default("unknown") // largecap | midcap | smallcap | microcap | unknown

  metrics StockMetrics?

  @@index([sector])
  @@index([marketCapCategory])
  @@map("stock_metadata")
}

model StockMetrics {
  symbol            String   @id
  companyName       String   @default("")
  sector            String   @default("Unknown")
  marketCapCategory String   @default("unknown")

  // OHLC
  closePrice        Decimal  @db.Decimal(12, 4)
  openPrice         Decimal  @db.Decimal(12, 4)
  highPrice         Decimal  @db.Decimal(12, 4)
  lowPrice          Decimal  @db.Decimal(12, 4)

  // Change metrics
  changePct         Decimal  @db.Decimal(8, 4)
  gapPct            Decimal  @db.Decimal(8, 4)

  // Volume
  volumeToday       BigInt
  avgVolume20       BigInt
  avgVolume50       BigInt
  volumeRatio       Decimal  @db.Decimal(8, 4)  // today / avg20

  // SMAs
  sma20             Decimal? @db.Decimal(12, 4)
  sma50             Decimal? @db.Decimal(12, 4)
  sma100            Decimal? @db.Decimal(12, 4)
  sma200            Decimal? @db.Decimal(12, 4)

  // EMAs
  ema20             Decimal? @db.Decimal(12, 4)
  ema50             Decimal? @db.Decimal(12, 4)
  ema100            Decimal? @db.Decimal(12, 4)
  ema200            Decimal? @db.Decimal(12, 4)

  // RSI
  rsi14             Decimal? @db.Decimal(6, 3)

  // MACD
  macd              Decimal? @db.Decimal(10, 4)
  macdSignal        Decimal? @db.Decimal(10, 4)
  macdHistogram     Decimal? @db.Decimal(10, 4)

  // ATR
  atr14             Decimal? @db.Decimal(10, 4)

  // 52-week range
  week52High          Decimal? @db.Decimal(12, 4)
  week52Low           Decimal? @db.Decimal(12, 4)
  distanceFrom52wHigh Decimal? @db.Decimal(8, 4)  // pct below 52w high
  distanceFrom52wLow  Decimal? @db.Decimal(8, 4)  // pct above 52w low

  // Boolean trend flags
  aboveSma20   Boolean @default(false)
  aboveSma50   Boolean @default(false)
  aboveSma100  Boolean @default(false)
  aboveSma200  Boolean @default(false)
  aboveEma20   Boolean @default(false)
  aboveEma50   Boolean @default(false)
  aboveEma100  Boolean @default(false)
  aboveEma200  Boolean @default(false)

  // Crossover flags (golden/death cross detection)
  crossover2050  Boolean @default(false)  // SMA20 crossed above SMA50 today
  crossover50100 Boolean @default(false)  // SMA50 crossed above SMA100 today
  crossover50200 Boolean @default(false)  // SMA50 crossed above SMA200 today

  // MACD crossover flags
  bullishMacdCross Boolean @default(false)
  bearishMacdCross Boolean @default(false)

  // 52-week milestone flags
  new52wHigh Boolean @default(false)
  new52wLow  Boolean @default(false)

  // Metadata
  candleDate DateTime @db.Date
  updatedAt  DateTime @updatedAt

  metadata StockMetadata? @relation(fields: [symbol], references: [symbol])

  @@index([sector])
  @@index([marketCapCategory])
  @@index([changePct])
  @@index([volumeRatio])
  @@index([rsi14])
  @@index([aboveSma20])
  @@index([aboveSma50])
  @@index([aboveSma100])
  @@index([aboveSma200])
  @@index([bullishMacdCross])
  @@index([bearishMacdCross])
  @@index([new52wHigh])
  @@index([new52wLow])
  @@index([candleDate])
  @@index([updatedAt])
  @@map("stock_metrics")
}

// ─── Pattern Search ───────────────────────────────────────────────────────────

model PatternVector {
  id               String   @id @default(uuid())
  symbol           String
  windowSize       Int
  startDate        DateTime @db.Date
  endDate          DateTime @db.Date
  normalizedSeries Json     // float[100] — normalized closing prices

  future5dReturn   Decimal? @db.Decimal(8, 4)
  future10dReturn  Decimal? @db.Decimal(8, 4)
  future20dReturn  Decimal? @db.Decimal(8, 4)
  future50dReturn  Decimal? @db.Decimal(8, 4)
  maxGain          Decimal? @db.Decimal(8, 4)
  maxDrawdown      Decimal? @db.Decimal(8, 4)

  createdAt        DateTime @default(now())

  @@unique([symbol, windowSize, startDate])
  @@index([symbol])
  @@index([windowSize])
  @@map("pattern_vectors")
}
