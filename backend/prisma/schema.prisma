generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id
  clerkUserId    String    @unique
  name           String    @default("")
  email          String    @unique
  role           String    @default("USER")
  plan           String    @default("FREE")
  reportsUsed    Int       @default(0)
  planStartDate  DateTime?
  planExpiryDate DateTime?
  isPremium      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Candle {
  symbol      String
  date        DateTime  @db.Date
  open        Decimal   @db.Decimal(12, 4)
  high        Decimal   @db.Decimal(12, 4)
  low         Decimal   @db.Decimal(12, 4)
  close       Decimal   @db.Decimal(12, 4)
  volume      BigInt
  dataQuality Int       @default(100)
  createdAt   DateTime  @default(now())

  @@id([symbol, date])
  @@index([symbol, date(sort: Desc)])
  @@map("candles")
}

model TechnicalAnalysisCache {
  symbol         String   @id
  resultJson     Json
  technicalScore Decimal  @db.Decimal(5, 2)
  candleDate     DateTime @db.Date
  calculatedAt   DateTime @default(now())
  isStale        Boolean  @default(false)

  @@map("technical_analysis_cache")
}

model ScoreHistory {
  id              BigInt   @id @default(autoincrement())
  symbol          String
  date            DateTime @db.Date
  technicalScore  Decimal  @db.Decimal(5, 2)
  technicalRating String
  confluenceScore Decimal? @db.Decimal(5, 2)
  recordedAt      DateTime @default(now())

  @@unique([symbol, date])
  @@index([symbol, date(sort: Desc)])
  @@map("score_history")
}

model IngestionLog {
  id             BigInt   @id @default(autoincrement())
  symbol         String
  runDate        DateTime @db.Date
  status         String
  candlesFetched Int?
  errorMessage   String?
  durationMs     Int?
  loggedAt       DateTime @default(now())

  @@map("ingestion_log")
}
