generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AnnualReport {
  id                   String    @id
  companyId            String
  financialYear        Int
  pdfUrl               String
  processed            Boolean   @default(false)
  processedAt          DateTime?
  createdAt            DateTime  @default(now())
  businessSegments     Json?
  futureOutlook        String?
  managementCommentary String?
  riskFactors          Json?
  Company              Company   @relation(fields: [companyId], references: [id])

  @@unique([companyId, financialYear])
}

model Company {
  id           String         @id
  name         String
  nseSymbol    String?        @unique
  createdAt    DateTime       @default(now())
  AnnualReport AnnualReport[]
}

model User {
  id            String                @id
  clerkUserId   String                @unique
  name          String                @default("")
  email         String                @unique
  phone         String                @default("")
  role          String                @default("USER")
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  registrations WebinarRegistration[]
}

enum ExperienceLevel {
  Beginner
  Intermediate
  Advanced
}

model Webinar {
  id                  String                @id @default(uuid())
  title               String
  slug                String                @unique
  description         String
  speaker             String
  thumbnail           String
  webinarDate         DateTime
  duration            Int
  meetingLink         String
  whatsappChannelLink String
  maxSeats            Int
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  registrations       WebinarRegistration[]

  @@map("webinars")
  @@index([slug])
  @@index([isActive])
}

model WebinarRegistration {
  id              String          @id @default(uuid())
  userId          String
  webinarId       String
  experienceLevel ExperienceLevel
  registeredAt    DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  webinar         Webinar         @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  @@unique([userId, webinarId])
  @@index([userId])
  @@index([webinarId])
  @@map("webinar_registrations")
}

model Trade {
  id             String   @id @default(uuid())
  userId         String   // Clerk User ID
  symbol         String
  instrumentType String   // Equity, Futures, Options
  direction      String   // Long, Short
  entryPrice     Float
  exitPrice      Float
  quantity       Float
  entryDate      DateTime
  exitDate       DateTime
  
  // Plan
  plannedStopLoss Float?
  plannedTarget   Float?
  
  // Setup
  strategy        String
  confidenceScore Int
  emotion         String?
  exitReason      String?
  mistakes        String[] // Array of mistake tags
  
  // Notes
  tradeIdea     String?
  lessonLearned String?
  
  // Options specific fields
  optionType  String?
  strikePrice Float?
  expiryDate  DateTime?
  premiumPaid Float?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id          String   @id @default(uuid())
  scamType    String   @map("scam_type")
  lossRange   String   @map("loss_range")
  description String
  evidenceUrl String?  @map("evidence_url")
  name        String
  phone       String
  email       String
  status      String   @default("pending") // pending, verified, rejected
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("reports")
}

model Story {
  id        String   @id @default(uuid())
  reportId  String   @map("report_id")
  title     String
  summary   String
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("stories")
}

model Alert {
  id          String   @id @default(uuid())
  title       String
  description String
  riskLevel   String   @map("risk_level") // High, Medium, Low
  status      String   @default("under_investigation") // under_investigation, verified, closed
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("alerts")
}

model Statistics {
  id              String   @id @default("singleton")
  totalVictims    Int      @default(0) @map("total_victims")
  totalLosses     Float    @default(0.0) @map("total_losses")
  verifiedReports Int      @default(0) @map("verified_reports")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("statistics")
}

model Comment {
  id        String   @id @default(uuid())
  text      String
  author    String   @default("Anonymous")
  reported  Boolean  @default(false)
  upvotes   Int      @default(0)
  downvotes Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("comments")
}
